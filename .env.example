# --- Spotify (create an app at https://developer.spotify.com/dashboard) ---
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Must exactly match a Redirect URI registered on your Spotify app
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Gemini (create a key at https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# --- GenreSync behavior ---
# How often (ms) to poll Liked Songs for new tracks
POLL_INTERVAL_MS=60000
# How often (ms) to check managed playlists for user corrections (moves/removals)
CORRECTION_CHECK_INTERVAL_MS=300000
# Rebuild the taste profile after this many new classifications
PROFILE_REBUILD_EVERY_N=10
# Max number of new playlists GenreSync is allowed to auto-create
MAX_AUTO_PLAYLISTS=25
# Local port used only during the one-time OAuth login flow
AUTH_CALLBACK_PORT=8888
